# 智能舆情监测平台 — 环境变量
# 将此文件复制为 .env 并填入实际值

# Serper.dev 搜索 API (https://serper.dev — 免费 2500次/月)
SERPER_API_KEY=your_serper_key_here

# DeepSeek LLM API (https://platform.deepseek.com)
DEEPSEEK_API_KEY=your_deepseek_key_here

# Bing News Search API (可选，不填则仅使用 Serper + DeepSeek fallback)
# BING_API_KEY=your_bing_key_here

# JWT 密钥 — 首次启动时自动生成写入 .env，无需手动设置
# JWT_SECRET=auto_generated
