{
  "version": "2.0",
  "envId": "{{envId}}",
  "region": "ap-shanghai",
  "framework": {
    "name": "intelligent-sentiment-monitor",
    "plugins": {
      "server": {
        "use": "@cloudbase/framework-plugin-container",
        "inputs": {
          "serviceName": "sentiment-backend",
          "servicePath": "/backend",
          "containerPort": 8000,
          "dockerfilePath": "backend/Dockerfile",
          "envVariables": {
            "SERPER_API_KEY": "",
            "DEEPSEEK_API_KEY": "",
            "BING_API_KEY": "",
            "JWT_SECRET": ""
          },
          "cpu": 0.25,
          "mem": 0.5,
          "minNum": 0,
          "maxNum": 3,
          "policyType": "cpu",
          "policyThreshold": 60
        }
      },
      "client": {
        "use": "@cloudbase/framework-plugin-website",
        "inputs": {
          "outputPath": "/frontend/dist",
          "cloudPath": "/",
          "envVariables": {
            "VITE_API_URL": ""
          }
        }
      }
    }
  }
}
